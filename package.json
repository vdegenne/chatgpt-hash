{
	"name": "chatgpt-hash",
	"type": "module",
	"devDependencies": {
		"@vdegenne/rollup": "^0.1.11",
		"@webcomponents/webcomponentsjs": "^2.8.0",
		"html-vision": "^0.3.4",
		"toastit": "^2.2.2",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"wireit": "^0.14.12"
	},
	"wireit": {
		"build": {
			"command": "rollup -c",
			"clean": "if-file-deleted",
			"files": [
				"./tsconfig.json",
				"./rollup.config.js",
				"./src"
			],
			"output": [
				"./content.js"
			]
		}
	},
	"scripts": {
		"build": "wireit"
	}
}
